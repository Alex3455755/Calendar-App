<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header containing Current Date -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_day_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="28"
            android:textColor="#FF7F50"
            android:textSize="26sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_month_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Октября"
                android:textColor="#2C3E50"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_day_of_week"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Четверг"
                android:textColor="#7F8C8D"
                android:textSize="11sp" />
        </LinearLayout>

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/app_launcher_icon" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="#D0E1FD" />

    <!-- Container for dynamic events list -->
    <LinearLayout
        android:id="@+id/widget_events_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Empty state text -->
        <TextView
            android:id="@+id/widget_empty_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="На сегодня событий нет ✨"
            android:textColor="#7F8C8D"
            android:textSize="13sp"
            android:textStyle="italic"
            android:visibility="gone" />

        <!-- Event Row 1 -->
        <LinearLayout
            android:id="@+id/widget_event_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="visible">

            <ImageView
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:src="@drawable/widget_coral_bullet" />

            <TextView
                android:id="@+id/widget_event_text_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="14:00 - Встреча"
                android:textColor="#2C3E50"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Event Row 2 -->
        <LinearLayout
            android:id="@+id/widget_event_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="visible">

            <ImageView
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:src="@drawable/widget_coral_bullet" />

            <TextView
                android:id="@+id/widget_event_text_2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="18:30 - Спортзал"
                android:textColor="#2C3E50"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Event Row 3 -->
        <LinearLayout
            android:id="@+id/widget_event_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="visible">

            <ImageView
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:src="@drawable/widget_coral_bullet" />

            <TextView
                android:id="@+id/widget_event_text_3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="20:00 - Чтение книги"
                android:textColor="#2C3E50"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Extra indicator (if more than 3) -->
        <TextView
            android:id="@+id/widget_more_events_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="+ еще 2 события..."
            android:textColor="#FF7F50"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>
</LinearLayout>
